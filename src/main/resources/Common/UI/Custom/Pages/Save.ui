$C = "../Common.ui";
$Sounds = "../Sounds.ui";
$Browser = "PrefabBrowser.ui";

@Red = #ff0000;
@InputLabel = Label {
  Anchor: (Left: 6, Right: 16, Width: 220);
  Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center);
};

@ContainerWidth = 560;

@ContentPadding = 16;

@PanelPadding = 12;

$C.@PageOverlay #MainPage {
  LayoutMode: Middle;
  Group {
    Anchor: (Width: 600);
    LayoutMode: Top;
    TabNavigation #Tabs {
      Anchor: (Height: 66, Left: 2, Right: 0);
      Style: $C.@TopTabsStyle;
      SelectedTab: "Selection";
      TabButton #Selection {
        Icon: "../Icons/Selection.png";
        TooltipText: %mcreator.ui.save.tabSelection;
        Id: "Selection";
      }
      TabButton #Prefab {
        Icon: "../Icons/Prefab.png";
        TooltipText: %mcreator.ui.save.tabPrefab;
        Id: "Prefab";
      }
    }
  }
  Group #Main {
    Anchor: (Width: 600);
    $C.@Container #SelectionView {
      Visible: true;
      #Title {
        $C.@Title {
          @Text = %mcreator.ui.save.selectionTitle;
        }
      }
      #Content {
        LayoutMode: Top;
        Padding: (Full: @ContentPadding);
        Label #SelectionNotification {
          Anchor: (Bottom: 0);
          Padding: (Bottom: 8);
          Visible: false;
          Style: (FontSize: 16, TextColor: @Red, Wrap: true);
          Text: "";
        }
        Group #Settings {
          LayoutMode: Top;
          Anchor: (Bottom: 0);
          Group #Name {
            LayoutMode: Left;
            Anchor: (Height: 35, Bottom: 16);
            Label {
              Text: %mcreator.ui.save.nameLabel;
              Anchor: (Left: 0, Top: 8);
              Style: $C.@DefaultLabelStyle;
            }
            $C.@TextField #NameInput {
              @Anchor = (Left: 8, Right: 0);
              FlexWeight: 1;
              MaxLength: 1024;
              PlaceholderText: %mcreator.ui.save.nameInputPlaceholder;
            }
          }
          Group #SelectedEntities {
            LayoutMode: Top;
            Anchor: (Bottom: 16);
            Label #Label {
              Text: %mcreator.ui.save.selectedEntitiesLabel;
              Anchor: (Bottom: 4);
              Style: $C.@DefaultLabelStyle;
              TooltipText: %mcreator.ui.save.entitiesTooltip;
            }
            Group #Entities {
              Anchor: (Height: 100);
              Background: (
                TexturePath: "../Common/ContainerPanelPatch.png",
                Border: 4,
              );
              Padding: (Full: @PanelPadding);
              LayoutMode: TopScrolling;
              ScrollbarStyle: $C.@DefaultScrollbarStyle;
            }
            Label #AutoGroup {
              Text: %mcreator.ui.save.autoGroup;
              Anchor: (Bottom: 4);
              Style: (...$C.@DefaultLabelStyle, FontSize: 14, Wrap: true);
            }
            Group #GroupingDist {
              LayoutMode: Left;
              Anchor: (Bottom: 4);

              Label #Label {
                Anchor: (Left: 0, Top: 8);
                Text: %mcreator.ui.save.groupingDist;
                Style: $C.@DefaultLabelStyle;
              }

              $C.@NumberField #DistInput {
                @Anchor = (Left: 8, Right: 8);
                FlexWeight: 1;
                MaxLength: 1024;
                Value: 1.5;
                Format: (MaxDecimalPlaces: 1, DefaultValue: 1.5);
              }
            }
          }
          Group #Pack {
            LayoutMode: Left;
            Anchor: (Height: 35, Bottom: 16);
            Label {
              Text: %mcreator.ui.save.packLabel;
              Anchor: (Left: 0, Top: 8);
              Style: $C.@DefaultLabelStyle;
            }
            $C.@DropdownBox #PackDropdown {
              @Anchor = (Left: 8, Right: 0);
              FlexWeight: 1;
              Value: "";
            }
          }
          Group #AutoReplace {
            LayoutMode: Left;
            Anchor: (Height: 35, Bottom: 16);
            $C.@CheckBoxWithLabel {
              @Text = %mcreator.ui.save.autoReplace;
              @Checked = true;
            }
          }
          Group #CreateItem {
            LayoutMode: Left;
            Anchor: (Height: 35, Bottom: 16);
            $C.@CheckBoxWithLabel {
              @Text = %mcreator.ui.save.createItem;
              @Checked = true;
            }
          }
          Group #Buttons {
            LayoutMode: Center;
            Anchor: (Top: 0);
            $C.@TextButton #GenerateButton {
              @Sounds = $Sounds.@SaveSettings;
              @Anchor = (Right: 4);
              Text: %mcreator.ui.generate;
              FlexWeight: 1;
            }
            $C.@SecondaryTextButton #CancelButton {
              @Sounds = $Sounds.@ButtonsCancel;
              @Anchor = (Left: 4);
              Text: %server.customUI.cancel;
              FlexWeight: 1;
            }
          }
        }
      }
    }
    $C.@Container #PrefabView {
      Visible: false;
      #Title {
        $C.@Title {
          @Text = %mcreator.ui.save.prefabTitle;
        }
      }
      #Content {
        LayoutMode: Top;
        Padding: (Full: @ContentPadding);
        Label #PrefabNotification {
          Anchor: (Bottom: 0);
          Padding: (Bottom: 8);
          Visible: false;
          Style: (FontSize: 16, TextColor: @Red, Wrap: true);
          Text: "";
        }
        Group #Settings {
          LayoutMode: Top;
          Anchor: (Bottom: 0);
          Group #Name {
            LayoutMode: Left;
            Anchor: (Height: 35, Bottom: 16);
            Label {
              Text: %mcreator.ui.save.nameLabel;
              Anchor: (Left: 0, Top: 8);
              Style: $C.@DefaultLabelStyle;
            }
            $C.@TextField #NameInput {
              @Anchor = (Left: 8, Right: 0);
              FlexWeight: 1;
              MaxLength: 1024;
              PlaceholderText: %mcreator.ui.save.nameInputPlaceholder;
            }
          }
          Group #PrefabSelection {
            LayoutMode: Left;
            Anchor: (Bottom: 16);
            Label #Label {
              Text: %mcreator.ui.save.prefabSelectionLabel;
              Anchor: (Left: 0, Top: 14);
              Style: $C.@DefaultLabelStyle;
            }
            $C.@TextField #Input {
              Anchor: (Height: 40, Left: 8, Right: 8);
              FlexWeight: 1;
              MaxLength: 4096;
              PlaceholderText: %mcreator.ui.save.prefabSelectionPlaceholder;
              IsReadOnly: true;
            }

            $C.@SecondaryTextButton #BrowseButton {
              @Anchor = (Width: 120, Right: 0);
              Text: %server.customUI.prefabEditorSettings.browse;
            }
          }
          Group #SelectedEntities {
            LayoutMode: Top;
            Anchor: (Bottom: 16);
            Label #Label {
              Text: %mcreator.ui.save.selectedEntitiesLabel;
              Anchor: (Bottom: 4);
              Style: $C.@DefaultLabelStyle;
              TooltipText: %mcreator.ui.save.entitiesTooltip;
            }
            Group #Entities {
              Anchor: (Height: 100);
              Background: (
                TexturePath: "../Common/ContainerPanelPatch.png",
                Border: 4,
              );
              Padding: (Full: @PanelPadding);
              LayoutMode: TopScrolling;
              ScrollbarStyle: $C.@DefaultScrollbarStyle;
            }
          }
          Group #Pack {
            LayoutMode: Left;
            Anchor: (Height: 35, Bottom: 16);
            Label {
              Text: %mcreator.ui.save.packLabel;
              Anchor: (Left: 0, Top: 8);
              Style: $C.@DefaultLabelStyle;
            }
            $C.@DropdownBox #PackDropdown {
              @Anchor = (Left: 8, Right: 0);
              FlexWeight: 1;
              Value: "";
            }
          }
          Group #CreateItem {
            LayoutMode: Left;
            Anchor: (Height: 35, Bottom: 16);
            $C.@CheckBoxWithLabel {
              @Text = %mcreator.ui.save.createItem;
              @Checked = true;
            }
          }
          Group #Buttons {
            LayoutMode: Center;
            Anchor: (Top: 0);
            $C.@TextButton #GenerateButton {
              @Sounds = $Sounds.@SaveSettings;
              @Anchor = (Right: 4);
              Text: %mcreator.ui.generate;
              FlexWeight: 1;
            }
            $C.@SecondaryTextButton #CancelButton {
              @Sounds = $Sounds.@ButtonsCancel;
              @Anchor = (Left: 4);
              Text: %server.customUI.cancel;
              FlexWeight: 1;
            }
          }
        }
      }
    }
  }
}

$C.@PageOverlay #BrowserPage {
  LayoutMode: Middle;
  Visible: false;


  Group {
    Anchor: (Height: 700);
    LayoutMode: Center;
    $C.@DecoratedContainer {
      Anchor: (Width: 700, Height: 700);

      #Title {
        $C.@Title {
          @Text = %server.customUI.prefabEditorSettings.browser.title;
        }
      }

      #Content {
        LayoutMode: Top;
        Padding: (Full: 16);

        Label #CurrentPath {
          Anchor: (Bottom: 8, Horizontal: 4);
          Style: (
            ...$C.@DefaultLabelStyle,
            FontSize: 12,
            TextColor: #6a7d8f,
          );
          Text: "";
        }

        Group #BrowserContent {
          FlexWeight: 1;
          $Browser.@PrefabBrowserContent {
          }
        }

        Group #BrowserButtons {
          LayoutMode: Center;
          Anchor: (Top: 8);

          $C.@TextButton #ConfirmButton {
            @Sounds = $Sounds.@SaveSettings;
            @Anchor = (Left: 4, Right: 4);
            Text: %server.customUI.prefabEditorSettings.browser.confirm;
            FlexWeight: 1;
          }

          $C.@SecondaryTextButton #CancelButton {
            @Sounds = $Sounds.@ButtonsCancel;
            @Anchor = (Left: 4);
            Text: %server.customUI.cancel;
            FlexWeight: 1;
          }
        }
      }
    }
    $C.@Container #BrowserPreviewBackdrop {
      Anchor: (Left: 10, Top: 0, Width: 600, Height: 700);

      #Title {
        $C.@Title {
          @Text = %server.customUI.prefabBrowser.previewTitle;
        }
      }

      #Content {
        LayoutMode: Full;

        PrefabPreviewComponent #BrowserPrefabPreview {
          AllowDragYaw: true;
          AllowDragPitch: true;
          AllowZoom: true;
          AllowPan: true;
          ShowAnchor: true;
        }
      }
    }
  }
}
